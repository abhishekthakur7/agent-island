    {"name": "same-title-or-fullscreen-space-change", "application": "running", "permission": "granted", "election": "person-requested", "currentMatchingWindows": 2, "ignoredPresentationSignals": ["title", "fullScreen", "space"], "expectedLevel": "appOnly"},
